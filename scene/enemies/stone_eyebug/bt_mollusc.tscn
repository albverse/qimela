[gd_scene load_steps=11 format=3]

; === Beehave 内置节点脚本 ===
[ext_resource type="Script" path="res://addons/beehave/nodes/beehave_tree.gd" id="bt_tree"]
[ext_resource type="Script" path="res://addons/beehave/nodes/composites/selector_reactive.gd" id="selector_reactive"]
[ext_resource type="Script" path="res://addons/beehave/nodes/composites/sequence_reactive.gd" id="sequence_reactive"]

; === 自定义 Condition 脚本 ===
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/conditions/cond_mollusc_see_shell.gd" id="cond_see_shell"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/conditions/cond_mollusc_player_in_range.gd" id="cond_player"]

; === 自定义 Action 脚本 ===
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/actions/act_mollusc_return_shell.gd" id="act_return"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/actions/act_mollusc_attack.gd" id="act_attack"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/actions/act_mollusc_escape.gd" id="act_escape"]

; =============================================================================
; BeehaveTree 根节点
; actor 自动取父节点（Mollusc CharacterBody2D）
; =============================================================================
[node name="BeehaveTree" type="Node"]
script = ExtResource("bt_tree")

; =============================================================================
; RootSelector: SelectorReactiveComposite
; 优先级：回壳 > 攻击 > 逃跑（兜底）
; =============================================================================
[node name="RootSelector" type="Node" parent="."]
script = ExtResource("selector_reactive")

; --- 1. Seq_ReturnShell（最高优先级）---
[node name="Seq_ReturnShell" type="Node" parent="RootSelector"]
script = ExtResource("sequence_reactive")

[node name="Cond_SeeEmptyShell" type="Node" parent="RootSelector/Seq_ReturnShell"]
script = ExtResource("cond_see_shell")

[node name="Act_ReturnToShell" type="Node" parent="RootSelector/Seq_ReturnShell"]
script = ExtResource("act_return")

; --- 2. Seq_Attack（玩家进入范围）---
[node name="Seq_Attack" type="Node" parent="RootSelector"]
script = ExtResource("sequence_reactive")

[node name="Cond_PlayerInRange" type="Node" parent="RootSelector/Seq_Attack"]
script = ExtResource("cond_player")

[node name="Act_AttackSequence" type="Node" parent="RootSelector/Seq_Attack"]
script = ExtResource("act_attack")

; --- 3. Act_Escape（兜底逃跑，永远 RUNNING）---
[node name="Act_Escape" type="Node" parent="RootSelector"]
script = ExtResource("act_escape")
