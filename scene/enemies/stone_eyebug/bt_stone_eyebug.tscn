[gd_scene load_steps=15 format=3]

; === Beehave 内置节点脚本 ===
[ext_resource type="Script" path="res://addons/beehave/nodes/beehave_tree.gd" id="bt_tree"]
[ext_resource type="Script" path="res://addons/beehave/nodes/composites/selector_reactive.gd" id="selector_reactive"]
[ext_resource type="Script" path="res://addons/beehave/nodes/composites/sequence_reactive.gd" id="sequence_reactive"]

; === 自定义 Condition 脚本 ===
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/conditions/cond_seb_mode_is.gd" id="cond_mode_is"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/conditions/cond_seb_player_in_detect.gd" id="cond_player"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/conditions/cond_seb_attack_ready.gd" id="cond_atk_ready"]

; === 自定义 Action 脚本 ===
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/actions/act_seb_flipped_loop.gd" id="act_flipped"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/actions/act_seb_shell_flow.gd" id="act_shell"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/actions/act_seb_attack.gd" id="act_attack"]
[ext_resource type="Script" path="res://scene/enemies/stone_eyebug/actions/act_seb_wander.gd" id="act_wander"]

; =============================================================================
; BeehaveTree 根节点
; actor 自动取父节点（StoneEyeBug CharacterBody2D）
; process_thread = PHYSICS（默认）
; =============================================================================
[node name="BeehaveTree" type="Node"]
script = ExtResource("bt_tree")

; =============================================================================
; RootSelector: SelectorReactiveComposite
; 优先级从上到下：
;   Flipped > ShellFlow > Attack > Wander（兜底）
; =============================================================================
[node name="RootSelector" type="Node" parent="."]
script = ExtResource("selector_reactive")

; --- 1. Seq_Flipped（最高优先级）---
[node name="Seq_Flipped" type="Node" parent="RootSelector"]
script = ExtResource("sequence_reactive")

[node name="Cond_ModeFlipped" type="Node" parent="RootSelector/Seq_Flipped"]
script = ExtResource("cond_mode_is")
target_mode = 3

[node name="Act_FlippedLoop" type="Node" parent="RootSelector/Seq_Flipped"]
script = ExtResource("act_flipped")

; --- 2. Seq_ShellFlow（缩壳/壳内/出壳）---
[node name="Seq_ShellFlow" type="Node" parent="RootSelector"]
script = ExtResource("sequence_reactive")

[node name="Cond_ModeShell" type="Node" parent="RootSelector/Seq_ShellFlow"]
script = ExtResource("cond_mode_is")
target_mode = 1

[node name="Act_ShellFlow" type="Node" parent="RootSelector/Seq_ShellFlow"]
script = ExtResource("act_shell")

; --- 2b. Seq_InShell（壳内等待）---
[node name="Seq_InShell" type="Node" parent="RootSelector"]
script = ExtResource("sequence_reactive")

[node name="Cond_ModeInShell" type="Node" parent="RootSelector/Seq_InShell"]
script = ExtResource("cond_mode_is")
target_mode = 2

[node name="Act_InShellWait" type="Node" parent="RootSelector/Seq_InShell"]
script = ExtResource("act_shell")

; --- 3. Seq_Attack（玩家进入检测区且攻击就绪）---
[node name="Seq_Attack" type="Node" parent="RootSelector"]
script = ExtResource("sequence_reactive")

[node name="Cond_PlayerInDetect" type="Node" parent="RootSelector/Seq_Attack"]
script = ExtResource("cond_player")

[node name="Cond_AttackReady" type="Node" parent="RootSelector/Seq_Attack"]
script = ExtResource("cond_atk_ready")

[node name="Act_AttackSequence" type="Node" parent="RootSelector/Seq_Attack"]
script = ExtResource("act_attack")

; --- 4. Act_Wander（兜底，永远 RUNNING）---
[node name="Act_Wander" type="Node" parent="RootSelector"]
script = ExtResource("act_wander")
