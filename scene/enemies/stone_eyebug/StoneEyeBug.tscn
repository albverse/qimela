; 软腹受击半径（比壳体小）；运行时 global_position 由 stone_eyebug.gd 骨骼追踪覆盖
radius = 12.0

; =============================================================================
; StoneEyeBug（石眼虫 壳体阶段）
; collision_layer = 4  # EnemyBody(3)
; collision_mask = 1   # World(1)
; =============================================================================
[node name="StoneEyeBug" type="CharacterBody2D"]
collision_layer = 4
collision_mask = 1
script = ExtResource("1_script")
mollusc_scene = ExtResource("5_mollusc")

[node name="Sprite2D" type="Sprite2D" parent="."]
; 占位精灵，待 Spine 资源完成后替换为 SpineSprite

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("body_shape")

; 壳体受击盒：layer=8(EnemyHurtbox)，在 FLIPPED 阶段由 _update_hurtbox_states() 禁用
[node name="Hurtbox" type="Area2D" parent="."]
collision_layer = 8
collision_mask = 0
script = ExtResource("2_hurtbox")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Hurtbox"]
shape = SubResource("hurtbox_shape")

; 软腹受击盒：layer=8(EnemyHurtbox)，默认 monitoring=false
; global_position 每帧由 stone_eyebug.gd._update_soft_hurtbox_position() 追踪骨骼 "belly"
; monitoring 由 _update_hurtbox_states() 按 mode 控制：
;   NORMAL          → true （打中软腹触发缩壳）
;   RETREATING/IN_SHELL/EMPTY_SHELL → false
;   FLIPPED+struggle → true （打中软腹触发分裂逃跑）
[node name="SoftHurtbox" type="Area2D" parent="."]
collision_layer = 8
collision_mask = 0
monitoring = false
script = ExtResource("6_soft_hurtbox")

[node name="CollisionShape2D" type="CollisionShape2D" parent="SoftHurtbox"]
shape = SubResource("soft_hurtbox_shape")

[node name="LightReceiver" type="Area2D" parent="."]
collision_layer = 16
collision_mask = 16
script = ExtResource("3_light_recv")

[node name="CollisionShape2D" type="CollisionShape2D" parent="LightReceiver"]
